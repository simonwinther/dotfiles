{
  "manifest_version": 3,
  "name": "My Custom Keybinds",
  "version": "0.1.0",
  "description": "A lightweight personal keybind layer for the browser.",
  "permissions": ["tabs"],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "duplicate-tab": {
      "suggested_key": {
        "default": "Alt+C"
      },
      "description": "Clone the current tab"
    },
    "show-keybinds": {
      "suggested_key": {
        "default": "Alt+K"
      },
      "description": "Show custom keybinds"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["keybinds.js", "content.js"],
      "run_at": "document_start"
    }
  ]
}

#!/usr/bin/env bash
set -u

umask 077

CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/openai-dictation"
CONFIG_FILE="$CONFIG_DIR/config.env"
SECRETS_FILE="$CONFIG_DIR/secrets.env"
RUNTIME_DIR="${XDG_RUNTIME_DIR:-/tmp}/openai-dictation"
PID_FILE="$RUNTIME_DIR/record.pid"
STATE_FILE="$RUNTIME_DIR/state.env"
RECORDER_ERR_FILE="$RUNTIME_DIR/recorder.err"
OVERLAY_PID_FILE="$RUNTIME_DIR/loading.pid"
LAST_TXT="/tmp/openai-dictation-last.txt"
LAST_LOG="/tmp/openai-dictation-last.log"

OPENAI_API_URL="${OPENAI_API_URL:-https://api.openai.com/v1/audio/transcriptions}"
OPENAI_MODEL="${OPENAI_MODEL:-gpt-4o-mini-transcribe}"
OPENAI_LANGUAGE="${OPENAI_LANGUAGE:-en}"
OPENAI_PROMPT="${OPENAI_PROMPT:-}"

RECORD_RATE="${RECORD_RATE:-16000}"
RECORD_CHANNELS="${RECORD_CHANNELS:-1}"
RECORD_FORMAT="${RECORD_FORMAT:-s16}"
RECORD_LATENCY="${RECORD_LATENCY:-20ms}"
MIN_AUDIO_BYTES="${MIN_AUDIO_BYTES:-4096}"
MIN_RECORDING_MS="${MIN_RECORDING_MS:-1000}"
KEEP_AUDIO="${KEEP_AUDIO:-0}"

AUTO_PASTE="${AUTO_PASTE:-0}"
PASTE_METHOD="${PASTE_METHOD:-hyprctl-ctrl-shift-v}"
PASTE_DELAY="${PASTE_DELAY:-0.08}"
SHOW_LOADING="${SHOW_LOADING:-1}"
LOADING_OVERLAY_CMD="${LOADING_OVERLAY_CMD:-$HOME/.local/bin/openai-dictation-overlay}"
TRANSCRIBE_OVERLAY_MIN_MS="${TRANSCRIBE_OVERLAY_MIN_MS:-360}"
NOTIFY="${NOTIFY:-0}"
CURL_CONNECT_TIMEOUT="${CURL_CONNECT_TIMEOUT:-10}"
CURL_MAX_TIME="${CURL_MAX_TIME:-120}"

if [ -f "$CONFIG_FILE" ]; then
  # shellcheck disable=SC1090
  . "$CONFIG_FILE"
fi

if [ -f "$SECRETS_FILE" ]; then
  # shellcheck disable=SC1090
  . "$SECRETS_FILE"
fi

now_ms() {
  date +%s%3N
}

init_runtime() {
  mkdir -p "$RUNTIME_DIR"
  chmod 700 "$RUNTIME_DIR"
}

log() {
  init_runtime
  local line
  line="$(date -Is) $*"
  printf '%s\n' "$line" >> "$LAST_LOG"
  printf '%s\n' "$line" >&2
}

notify_msg() {
  local title="$1"
  local body="${2:-}"

  [ "${NOTIFY:-1}" = "1" ] || return 0
  command -v notify-send >/dev/null 2>&1 || return 0
  notify-send -a "OpenAI Dictation" "$title" "$body" >/dev/null 2>&1 || true
}

is_true() {
  case "${1:-}" in
    1|true|TRUE|yes|YES|on|ON) return 0 ;;
    *) return 1 ;;
  esac
}

need_cmds() {
  local missing=()
  local cmd

  for cmd in "$@"; do
    if ! command -v "$cmd" >/dev/null 2>&1; then
      missing+=("$cmd")
    fi
  done

  if [ "${#missing[@]}" -gt 0 ]; then
    printf 'Missing required command(s): %s\n' "${missing[*]}" >&2
    printf 'Install only what is missing. On Arch, likely packages are: pipewire, curl, wl-clipboard, python, libnotify.\n' >&2
    return 1
  fi
}

check_api_key() {
  if [ -z "${OPENAI_API_KEY:-}" ] || [ "${OPENAI_API_KEY:-}" = "replace_me" ]; then
    cat >&2 <<EOF
OPENAI_API_KEY is not set.

Set it for the current shell:
  export OPENAI_API_KEY='sk-...'

Or store it in:
  $CONFIG_FILE

Example line:
  OPENAI_API_KEY='sk-...'

The scripts never hardcode your API key.
EOF
    return 1
  fi
}

recording_pid() {
  [ -f "$PID_FILE" ] || return 1
  local pid
  pid="$(cat "$PID_FILE" 2>/dev/null || true)"
  [ -n "$pid" ] || return 1
  kill -0 "$pid" 2>/dev/null || return 1
  printf '%s\n' "$pid"
}

active_window_address() {
  command -v hyprctl >/dev/null 2>&1 || return 0
  command -v jq >/dev/null 2>&1 || return 0

  hyprctl activewindow -j 2>/dev/null |
    jq -r 'select(.address != null and .address != "0x0") | .address' 2>/dev/null
}

focus_saved_window() {
  local address="${FOCUS_ADDRESS:-}"
  [ -n "$address" ] || return 0
  command -v hyprctl >/dev/null 2>&1 || return 0

  if hyprctl dispatch focuswindow "address:$address" >/dev/null 2>&1; then
    log "event=focus_restore address=$address"
    sleep 0.06
  else
    log "event=focus_restore_failed address=$address"
  fi
}

cleanup_state() {
  rm -f "$PID_FILE" "$STATE_FILE"
}

cleanup_audio() {
  local audio_file="$1"

  if is_true "${KEEP_AUDIO:-0}"; then
    log "event=audio_kept audio_file=$audio_file"
  else
    rm -f -- "$audio_file"
    log "event=audio_removed audio_file=$audio_file"
  fi
}

start_overlay() {
  local mode="$1"
  local audio_file="${2:-}"
  local start_ms="${3:-}"

  is_true "${SHOW_LOADING:-1}" || return 0
  [ -x "$LOADING_OVERLAY_CMD" ] || return 0

  stop_overlay

  "$LOADING_OVERLAY_CMD" "$mode" "$audio_file" "$start_ms" >/dev/null 2>&1 &
  local pid="$!"
  printf '%s\n' "$pid" > "$OVERLAY_PID_FILE"
  log "event=overlay_start mode=$mode pid=$pid"

  if [ -n "${FOCUS_ADDRESS:-}" ]; then
    sleep 0.05
    focus_saved_window
  fi
}

stop_overlay() {
  [ -f "$OVERLAY_PID_FILE" ] || return 0

  local pid
  pid="$(cat "$OVERLAY_PID_FILE" 2>/dev/null || true)"
  rm -f "$OVERLAY_PID_FILE"
  [ -n "$pid" ] || return 0

  if kill -0 "$pid" 2>/dev/null; then
    kill "$pid" 2>/dev/null || true
    log "event=overlay_stop pid=$pid"
  fi
}

sleep_ms() {
  local ms="$1"
  local seconds

  [ "$ms" -gt 0 ] || return 0
  printf -v seconds '%d.%03d' "$((ms / 1000))" "$((ms % 1000))"
  sleep "$seconds"
}

finish_transcribe_overlay() {
  local overlay_start_ms="${1:-0}"
  local elapsed_ms remaining_ms

  [ -f "$OVERLAY_PID_FILE" ] || {
    stop_overlay
    return 0
  }

  if [ "$overlay_start_ms" -gt 0 ] && [ "${TRANSCRIBE_OVERLAY_MIN_MS:-0}" -gt 0 ]; then
    elapsed_ms=$(( $(now_ms) - overlay_start_ms ))
    remaining_ms=$(( TRANSCRIBE_OVERLAY_MIN_MS - elapsed_ms ))
    sleep_ms "$remaining_ms"
  fi

  stop_overlay
}

write_state() {
  local pid="$1"
  local audio_file="$2"
  local start_ms="$3"
  local focus_address="${4:-}"

  {
    printf 'PID=%q\n' "$pid"
    printf 'AUDIO_FILE=%q\n' "$audio_file"
    printf 'START_MS=%q\n' "$start_ms"
    printf 'FOCUS_ADDRESS=%q\n' "$focus_address"
  } > "$STATE_FILE"
  printf '%s\n' "$pid" > "$PID_FILE"
}

load_state() {
  if [ ! -f "$STATE_FILE" ]; then
    return 1
  fi

  # shellcheck disable=SC1090
  . "$STATE_FILE"
  [ -n "${PID:-}" ] && [ -n "${AUDIO_FILE:-}" ] && [ -n "${START_MS:-}" ]
}

start_recording() {
  init_runtime
  need_cmds pw-record date || return 1
  check_api_key || return 1

  if pid="$(recording_pid)"; then
    printf 'OpenAI dictation is already recording with PID %s.\n' "$pid" >&2
    return 0
  fi

  : > "$LAST_LOG"
  chmod 600 "$LAST_LOG"
  : > "$RECORDER_ERR_FILE"
  chmod 600 "$RECORDER_ERR_FILE"
  rm -f "$LAST_TXT"
  cleanup_state

  local start_ms audio_file pid focus_address
  start_ms="$(now_ms)"
  audio_file="$RUNTIME_DIR/recording-$start_ms.wav"
  focus_address="$(active_window_address)"

  pw-record \
    --rate "$RECORD_RATE" \
    --channels "$RECORD_CHANNELS" \
    --format "$RECORD_FORMAT" \
    --latency "$RECORD_LATENCY" \
    "$audio_file" >/dev/null 2> "$RECORDER_ERR_FILE" &
  pid="$!"

  sleep 0.08
  if ! kill -0 "$pid" 2>/dev/null; then
    log "event=start_failed pid=$pid audio_file=$audio_file"
    sed -n '1,20p' "$RECORDER_ERR_FILE" >&2
    cleanup_state
    return 1
  fi

  write_state "$pid" "$audio_file" "$start_ms" "$focus_address"
  log "event=start pid=$pid audio_file=$audio_file model=$OPENAI_MODEL rate_hz=$RECORD_RATE channels=$RECORD_CHANNELS latency=$RECORD_LATENCY focus_address=${focus_address:-none}"
  FOCUS_ADDRESS="$focus_address"
  start_overlay record "$audio_file" "$start_ms"
  notify_msg "OpenAI dictation recording" "Release the key or run openai-dictate-stop to transcribe."
}

stop_recorder_process() {
  local pid="$1"

  kill -INT "$pid" 2>/dev/null || kill -TERM "$pid" 2>/dev/null || true

  local i
  for i in $(seq 1 100); do
    if ! kill -0 "$pid" 2>/dev/null; then
      return 0
    fi
    sleep 0.02
  done

  kill -TERM "$pid" 2>/dev/null || true
  for i in $(seq 1 50); do
    if ! kill -0 "$pid" 2>/dev/null; then
      return 0
    fi
    sleep 0.02
  done

  kill -KILL "$pid" 2>/dev/null || true
}

parse_transcript() {
  local response_file="$1"

  python3 - "$response_file" <<'PY'
import json
import sys
from pathlib import Path

path = Path(sys.argv[1])
try:
    data = json.loads(path.read_text(encoding="utf-8"))
except Exception as exc:
    print(f"Could not parse OpenAI response as JSON: {exc}", file=sys.stderr)
    sys.exit(1)

if isinstance(data, dict) and "error" in data:
    err = data["error"]
    if isinstance(err, dict):
        message = err.get("message") or err
    else:
        message = err
    print(f"OpenAI API error: {message}", file=sys.stderr)
    sys.exit(1)

text = data.get("text") if isinstance(data, dict) else None
if not isinstance(text, str):
    print("OpenAI response did not contain a text field.", file=sys.stderr)
    sys.exit(1)

print(text.strip())
PY
}

paste_clipboard() {
  case "${PASTE_METHOD:-hyprctl-ctrl-shift-v}" in
    none)
      return 0
      ;;
    hyprctl-shift-insert)
      need_cmds hyprctl || return 1
      hyprctl dispatch sendshortcut "SHIFT, Insert," >/dev/null 2>&1
      ;;
    hyprctl-ctrl-v)
      need_cmds hyprctl || return 1
      hyprctl dispatch sendshortcut "CTRL, V," >/dev/null 2>&1
      ;;
    hyprctl-ctrl-shift-v)
      need_cmds hyprctl || return 1
      hyprctl dispatch sendshortcut "CTRL SHIFT, V," >/dev/null 2>&1
      ;;
    wtype-ctrl-v)
      need_cmds wtype || return 1
      wtype -M ctrl -k v -m ctrl >/dev/null 2>&1
      ;;
    wtype-ctrl-shift-v)
      need_cmds wtype || return 1
      wtype -M ctrl -M shift -k v -m shift -m ctrl >/dev/null 2>&1
      ;;
    ydotool-ctrl-v)
      need_cmds ydotool || return 1
      ydotool key 29:1 47:1 47:0 29:0 >/dev/null 2>&1
      ;;
    ydotool-ctrl-shift-v)
      need_cmds ydotool || return 1
      ydotool key 29:1 42:1 47:1 47:0 42:0 29:0 >/dev/null 2>&1
      ;;
    *)
      printf 'Unknown PASTE_METHOD: %s\n' "$PASTE_METHOD" >&2
      return 1
      ;;
  esac
}

transcribe_audio() {
  local audio_file="$1"
  local release_ms="$2"
  local recording_ms="$3"
  local stop_done_ms="$4"

  need_cmds curl python3 wl-copy date || return 1
  check_api_key || return 1

  local audio_bytes
  audio_bytes="$(wc -c < "$audio_file" 2>/dev/null || printf '0')"
  if [ "$audio_bytes" -lt "${MIN_AUDIO_BYTES:-4096}" ]; then
    log "event=audio_too_short audio_file=$audio_file bytes=$audio_bytes"
    log "timing recording_duration_ms=$recording_ms stop_finalize_ms=$((stop_done_ms - release_ms)) transcription_ms=0 total_after_release_ms=$(( $(now_ms) - release_ms ))"
    cleanup_audio "$audio_file"
    notify_msg "OpenAI dictation skipped" "Recording was too short."
    return 1
  fi

  local response_file curl_err upload_start_ms upload_end_ms transcribe_overlay_start_ms status text done_ms
  response_file="$(mktemp "${TMPDIR:-/tmp}/openai-dictation-response.XXXXXX.json")"
  curl_err="$(mktemp "${TMPDIR:-/tmp}/openai-dictation-curl.XXXXXX.err")"
  chmod 600 "$response_file" "$curl_err"

  local curl_args=(
    --config -
    --silent
    --show-error
    --fail-with-body
    --request POST
    "$OPENAI_API_URL"
    --form "model=$OPENAI_MODEL"
    --form "file=@$audio_file"
    --form "response_format=json"
  )

  if [ -n "${OPENAI_LANGUAGE:-}" ]; then
    curl_args+=(--form "language=$OPENAI_LANGUAGE")
  fi

  if [ -n "${OPENAI_PROMPT:-}" ]; then
    curl_args+=(--form "prompt=$OPENAI_PROMPT")
  fi

  upload_start_ms="$(now_ms)"
  log "event=transcribe_start audio_file=$audio_file bytes=$audio_bytes"
  transcribe_overlay_start_ms="$upload_start_ms"
  start_overlay transcribe

  if {
    printf 'header = "Authorization: Bearer %s"\n' "$OPENAI_API_KEY"
    printf 'connect-timeout = %s\n' "$CURL_CONNECT_TIMEOUT"
    printf 'max-time = %s\n' "$CURL_MAX_TIME"
  } | curl "${curl_args[@]}" > "$response_file" 2> "$curl_err"; then
    status=0
  else
    status=$?
  fi

  upload_end_ms="$(now_ms)"

  if [ "$status" -ne 0 ]; then
    stop_overlay
    log "event=transcribe_failed curl_status=$status transcription_ms=$((upload_end_ms - upload_start_ms))"
    log "timing recording_duration_ms=$recording_ms stop_finalize_ms=$((stop_done_ms - release_ms)) transcription_ms=$((upload_end_ms - upload_start_ms)) total_after_release_ms=$(( $(now_ms) - release_ms ))"
    if [ -s "$response_file" ]; then
      parse_transcript "$response_file" >/dev/null || true
      sed -n '1,20p' "$response_file" >&2
    fi
    if [ -s "$curl_err" ]; then
      sed -n '1,20p' "$curl_err" >&2
    fi
    notify_msg "OpenAI dictation failed" "See $LAST_LOG"
    cleanup_audio "$audio_file"
    rm -f "$response_file" "$curl_err"
    return "$status"
  fi

  if ! text="$(parse_transcript "$response_file" 2> "$curl_err")"; then
    stop_overlay
    log "event=parse_failed transcription_ms=$((upload_end_ms - upload_start_ms))"
    log "timing recording_duration_ms=$recording_ms stop_finalize_ms=$((stop_done_ms - release_ms)) transcription_ms=$((upload_end_ms - upload_start_ms)) total_after_release_ms=$(( $(now_ms) - release_ms ))"
    sed -n '1,20p' "$curl_err" >&2
    sed -n '1,20p' "$response_file" >&2
    notify_msg "OpenAI dictation failed" "Could not parse response."
    cleanup_audio "$audio_file"
    rm -f "$response_file" "$curl_err"
    return 1
  fi

  printf '%s' "$text" > "$LAST_TXT"
  chmod 600 "$LAST_TXT"
  printf '%s' "$text" | wl-copy --trim-newline
  finish_transcribe_overlay "$transcribe_overlay_start_ms"

  if is_true "$AUTO_PASTE" && [ -n "$text" ]; then
    sleep "$PASTE_DELAY"
    focus_saved_window
    if paste_clipboard; then
      log "event=auto_paste method=$PASTE_METHOD"
    else
      log "event=auto_paste_failed method=$PASTE_METHOD"
    fi
  fi

  done_ms="$(now_ms)"
  log "event=done transcript_chars=${#text} transcript_file=$LAST_TXT"
  log "timing recording_duration_ms=$recording_ms stop_finalize_ms=$((stop_done_ms - release_ms)) transcription_ms=$((upload_end_ms - upload_start_ms)) total_after_release_ms=$((done_ms - release_ms))"

  printf 'Transcript copied to clipboard (%d chars).\n' "${#text}"
  printf 'Timing: recording %.3fs, transcription %.3fs, total after release %.3fs.\n' \
    "$(python3 -c "print($recording_ms / 1000)")" \
    "$(python3 -c "print(($upload_end_ms - $upload_start_ms) / 1000)")" \
    "$(python3 -c "print(($done_ms - $release_ms) / 1000)")"
  printf 'Latest transcript: %s\n' "$LAST_TXT"
  printf 'Latest log: %s\n' "$LAST_LOG"

  notify_msg "OpenAI dictation copied" "$(( (done_ms - release_ms + 999) / 1000 ))s after release"
  cleanup_audio "$audio_file"
  rm -f "$response_file" "$curl_err"
}

discard_short_recording() {
  local audio_file="$1"
  local release_ms="$2"
  local recording_ms="$3"
  local stop_done_ms="$4"
  local min_seconds

  log "event=recording_too_short audio_file=$audio_file recording_ms=$recording_ms min_recording_ms=${MIN_RECORDING_MS:-1000}"
  log "timing recording_duration_ms=$recording_ms stop_finalize_ms=$((stop_done_ms - release_ms)) transcription_ms=0 total_after_release_ms=$(( $(now_ms) - release_ms ))"
  cleanup_audio "$audio_file"
  notify_msg "OpenAI dictation discarded" "Recording was under 1 second."
  printf -v min_seconds '%d.%03d' "$((MIN_RECORDING_MS / 1000))" "$((MIN_RECORDING_MS % 1000))"
  printf 'Recording was under %ss; discarded without sending to OpenAI.\n' "$min_seconds"
}

stop_recording() {
  init_runtime

  if ! load_state; then
    printf 'OpenAI dictation is not recording.\n' >&2
    cleanup_state
    return 1
  fi

  if ! kill -0 "$PID" 2>/dev/null; then
    printf 'Recorder process is not running; cleaning stale state.\n' >&2
    cleanup_state
    return 1
  fi

  local release_ms stop_done_ms recording_ms
  release_ms="$(now_ms)"
  log "event=release pid=$PID"
  stop_recorder_process "$PID"
  stop_done_ms="$(now_ms)"
  stop_overlay

  if [ -z "${START_MS:-}" ]; then
    START_MS="$release_ms"
  fi
  recording_ms=$((release_ms - START_MS))
  [ "$recording_ms" -ge 0 ] || recording_ms=0

  cleanup_state
  if [ "${MIN_RECORDING_MS:-0}" -gt 0 ] && [ "$recording_ms" -lt "${MIN_RECORDING_MS:-1000}" ]; then
    discard_short_recording "$AUDIO_FILE" "$release_ms" "$recording_ms" "$stop_done_ms"
    return 0
  fi

  transcribe_audio "$AUDIO_FILE" "$release_ms" "$recording_ms" "$stop_done_ms"
}

cancel_recording() {
  init_runtime

  if ! load_state; then
    printf 'OpenAI dictation is not recording.\n' >&2
    stop_overlay
    cleanup_state
    return 0
  fi

  local cancel_ms stop_done_ms recording_ms
  cancel_ms="$(now_ms)"
  log "event=cancel pid=${PID:-none}"

  if [ -n "${PID:-}" ] && kill -0 "$PID" 2>/dev/null; then
    stop_recorder_process "$PID"
  else
    log "event=cancel_stale_recorder pid=${PID:-none}"
  fi

  stop_done_ms="$(now_ms)"
  stop_overlay

  if [ -z "${START_MS:-}" ]; then
    START_MS="$cancel_ms"
  fi
  recording_ms=$((cancel_ms - START_MS))
  [ "$recording_ms" -ge 0 ] || recording_ms=0

  cleanup_state
  if [ -n "${AUDIO_FILE:-}" ]; then
    cleanup_audio "$AUDIO_FILE"
  fi

  log "timing recording_duration_ms=$recording_ms stop_finalize_ms=$((stop_done_ms - cancel_ms)) transcription_ms=0 total_after_release_ms=0"
  notify_msg "OpenAI dictation canceled" "Recording discarded."
  printf 'OpenAI dictation canceled; recording discarded.\n'
}

toggle_recording() {
  if recording_pid >/dev/null; then
    stop_recording
  else
    start_recording
  fi
}

once_recording() {
  start_recording || return 1
  printf 'Recording. Press Enter to stop and transcribe.\n' >&2
  trap 'printf "\nStopping...\n" >&2; stop_recording; exit $?' INT TERM
  read -r _ || true
  trap - INT TERM
  stop_recording
}

status_recording() {
  if pid="$(recording_pid)"; then
    printf 'recording pid=%s\n' "$pid"
    if load_state; then
      printf 'audio_file=%s\n' "$AUDIO_FILE"
      printf 'elapsed_ms=%s\n' "$(( $(now_ms) - START_MS ))"
    fi
  else
    printf 'idle\n'
  fi
}

show_help() {
  cat <<EOF
Usage: openai-dictate [start|stop|cancel|toggle|once|status|check]

Commands:
  start   Start recording in the background.
  stop    Stop recording, transcribe, copy to clipboard, and log timings.
  cancel  Stop recording and discard the audio without transcribing.
  toggle  Start if idle, stop if recording. This is the default.
  once    Terminal fallback: record until Enter, then transcribe.
  status  Show whether a recording is active.
  check   Check dependencies and API key.

Config:
  $CONFIG_FILE

Benchmark output:
  $LAST_TXT
  $LAST_LOG
EOF
}

main() {
  local cmd="${1:-toggle}"
  shift || true

  case "$cmd" in
    start) start_recording "$@" ;;
    stop) stop_recording "$@" ;;
    cancel) cancel_recording "$@" ;;
    toggle) toggle_recording "$@" ;;
    once) once_recording "$@" ;;
    status) status_recording "$@" ;;
    check)
      need_cmds pw-record curl python3 wl-copy date || return 1
      check_api_key
      ;;
    help|--help|-h) show_help ;;
    *)
      show_help >&2
      return 2
      ;;
  esac
}

main "$@"

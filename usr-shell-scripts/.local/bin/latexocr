#!/usr/bin/env bash
set -euo pipefail

API_URL="https://ocr.wintherne.dk/ocr?mode=hybrid"

TMP_IMG="$(mktemp --suffix=.png)"
trap 'rm -f "$TMP_IMG"' EXIT

notify-send "OCR" "Select a region..."

REGION="$(slurp || true)"

if [[ -z "$REGION" ]]; then
  notify-send "OCR" "Cancelled"
  exit 0
fi

grim -g "$REGION" "$TMP_IMG"

RESPONSE="$(
  curl -sS \
    --connect-timeout 10 \
    --max-time 300 \
    -X POST "$API_URL" \
    -F "file=@${TMP_IMG}"
)"

if ! printf '%s' "$RESPONSE" | jq -e . >/dev/null 2>&1; then
  printf '%s' "$RESPONSE" | wl-copy --trim-newline
  notify-send "OCR failed" "Invalid JSON. Copied raw response."
  exit 1
fi

SUCCESS="$(printf '%s' "$RESPONSE" | jq -r '.success // false')"

if [[ "$SUCCESS" != "true" ]]; then
  ERROR="$(printf '%s' "$RESPONSE" | jq -r '.error // .detail // "Unknown OCR error"')"
  printf '%s' "$RESPONSE" | wl-copy --trim-newline
  notify-send "OCR failed" "$ERROR"
  exit 1
fi

TEXT="$(
  printf '%s' "$RESPONSE" |
    jq -r '
      .markdown
      // .text
      // .result
      // .raw
      // .latex
      // .content
      // empty
    '
)"

if [[ -z "$TEXT" ]]; then
  printf '%s' "$RESPONSE" | wl-copy --trim-newline
  notify-send "OCR" "No clean text field found. Copied raw JSON."
  exit 0
fi

printf '%s' "$TEXT" | wl-copy --trim-newline
notify-send "OCR" "Copied result to clipboard"

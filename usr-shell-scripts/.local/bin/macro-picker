#!/usr/bin/env bash
set -euo pipefail

PICKER_CLASS="macro.picker"
FOCUS_TIMEOUT_MS=700
FOCUS_POLL_DELAY=0.02
PASTE_DELAY=0.15

need() {
  command -v "$1" >/dev/null 2>&1 || {
    printf 'missing: %s\n' "$1" >&2
    exit 127
  }
}

for cmd in fzf hyprctl python3 setsid wl-copy wtype; do
  need "$cmd"
done

active_window_class() {
  hyprctl activewindow -j 2>/dev/null | python3 -c '
import json
import sys

try:
    window = json.load(sys.stdin)
except Exception:
    sys.exit(1)

print(window.get("class") or window.get("initialClass") or "")
'
}

active_window_is_ghostty() {
  local class
  class="$(active_window_class)" || return 1

  case "$class" in
    com.mitchellh.ghostty|ghostty|*Ghostty*)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

wait_for_focus_to_leave_picker() {
  local class elapsed_ms
  elapsed_ms=0

  while ((elapsed_ms < FOCUS_TIMEOUT_MS)); do
    class="$(active_window_class 2>/dev/null || true)"
    if [[ -n "$class" && "$class" != "$PICKER_CLASS" ]]; then
      return 0
    fi

    sleep "$FOCUS_POLL_DELAY"
    elapsed_ms=$((elapsed_ms + 20))
  done

  return 1
}

paste_clipboard() {
  if active_window_is_ghostty; then
    wtype -M ctrl -M shift -k v -m shift -m ctrl >/dev/null 2>&1
  else
    wtype -M ctrl -k v -m ctrl >/dev/null 2>&1
  fi
}

copy_focus_and_paste() {
  local text="$1"

  printf '%s' "$text" | wl-copy --trim-newline
  hyprctl dispatch exec "$0 --paste" >/dev/null 2>&1 ||
    setsid -f "$0" --paste </dev/null >/dev/null 2>&1
}

paste_after_picker_closes() {
  sleep "$PASTE_DELAY"

  if [[ "$(active_window_class 2>/dev/null || true)" == "$PICKER_CLASS" ]]; then
    hyprctl dispatch focuswindow previous >/dev/null 2>&1 || true
  fi

  wait_for_focus_to_leave_picker || true
  paste_clipboard
}

if [[ "${1:-}" == "--paste" ]]; then
  paste_after_picker_closes
  exit
fi

choice="$(
  fzf \
    --delimiter='|' \
    --reverse \
    --border=rounded \
    --margin=5% \
    --prompt="Search > " \
    --color=fg:white,fg+:white,bg+:-1 \
    --color=hl:green,hl+:bright-green \
    --color=border:green,prompt:green,pointer:green,marker:green,spinner:green,info:gray \
    --preview-window=right:45%:wrap \
    --preview="echo {} | cut -d'|' -f2- | sed 's/^[ \t]*//'" <<'EOF'
Macro: Carpenter                 |   Java vs JavaScript is like a car vs a carpenter.
CALM: De-esculate                |   Quick reminder to keep things civil. If this topic's starting to cause friction, let's move on and keep the chat chill.
Mod: No Personal Commentary      |    Leave the comments to advice and help, and keep the personal commentary out of it.
Mod: Positive Environment        |    We aim to keep the learning environment here positive for all members, and this type of criticism doesn't adhere to that so please avoid it in the future.
EOF
)" || exit 0

[[ "$choice" == *"|"* ]] || exit 0
macro="${choice#*|}"
macro="${macro#"${macro%%[![:space:]]*}"}"

copy_focus_and_paste "$macro"

# OpenAI dictation config. 
# OPENAI_API_KEY goes in ~/.config/openai-dictation/secrets.env.


# cheaper/faster default
# OPENAI_MODEL='gpt-4o-mini-transcribe'

# # higher accuracy test
OPENAI_MODEL='gpt-4o-transcribe'

OPENAI_LANGUAGE=''
OPENAI_PROMPT='Audio may be English or Danish. Vocabulary and preferred spellings: Djafar, Hyprland, Waybar, Neovim, Omarchy.'

# Low-latency mono WAV recording through PipeWire.
RECORD_RATE=16000
RECORD_CHANNELS=1
RECORD_FORMAT='s16'
RECORD_LATENCY='20ms'
MIN_RECORDING_MS=1000
MAX_RECORDING_MS=300000
SKIP_SILENCE=1
SILENCE_MAX_DB=-50
KEEP_AUDIO=0

# ffmpeg preprocessing before upload. Collapses pauses longer than
# SILENCE_MIN_PAUSE seconds down to SILENCE_KEEP seconds, then speeds the
# audio up by SPEEDUP_FACTOR. Falls back to the raw recording whenever
# ffmpeg fails or the output looks broken. FFMPEG_PREPROCESS=0 disables it.
FFMPEG_PREPROCESS=1
TRIM_SILENCE=1
# Per-recording calibration: measures the clip's own speech level and sets
# the trim threshold SILENCE_SPEECH_MARGIN_DB below it, so breaths and key
# clicks above the noise floor still count as silence. Smaller margin =
# more aggressive trimming (try 10); raise it if quiet words get clipped.
# SILENCE_THRESHOLD_DB is only the fallback when calibration fails.
SILENCE_AUTO_THRESHOLD=1
SILENCE_SPEECH_MARGIN_DB=12
SILENCE_THRESHOLD_DB=-45

# SILENCE_MIN_PAUSE=0.45
SILENCE_MIN_PAUSE=0.7
# SILENCE_KEEP=0.25
SILENCE_KEEP=0.35

# I tested 1.5 for Danish, it made accuracy much worse. Even though very easy for English.
SPEEDUP_FACTOR=1.2

# Recordings shorter than this skip preprocessing.
PREPROCESS_MIN_MS=3000
# wav is safest; mp3 makes uploads ~4x smaller.
UPLOAD_CODEC=wav
# Debug banner (hyprctl notify) after each preprocessing run, e.g.
# "27.6s → trim 18.4s → 1.5x → 12.3s (-55%, ffmpeg 0.14s)". Set 0 to hide.
DEBUG_NOTIFY=1

# Clipboard is always updated. Auto-paste mirrors Super+V universal paste.
# In Ghostty, this falls back to Ctrl+Shift+V so Neovim keeps Ctrl+V.
# Set AUTO_PASTE=0 if you only want the transcript copied.
AUTO_PASTE=1
PASTE_METHOD='hyprctl-super-v'
PASTE_DELAY='0.08'
SHOW_LOADING=1
TRANSCRIBE_OVERLAY_MIN_MS=360
DUCK_VOLUME=1
VOLUME_DUCK_FACTOR=0.3

# Estimated recording cost shown in the overlay while recording.
# OpenAI pricing checked 2026-05-31: mini $0.003/min, full $0.006/min.
# USD/DKK checked 2026-05-31 at about 6.4104.
SHOW_COST_ESTIMATE=1
OPENAI_COST_USD_PER_MINUTE='auto'
OPENAI_COST_CURRENCY='DKK'
OPENAI_COST_USD_TO_DKK='6.4104'

NOTIFY=0
CURL_CONNECT_TIMEOUT=10
CURL_MAX_TIME=120

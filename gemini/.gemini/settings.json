{
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    },
    "disableYoloMode": false
  },
  "general": {
    "previewFeatures": true,
    "vimMode": true,
    "sessionRetention": {
      "enabled": true,
      "maxAge": "30d",
      "warningAcknowledged": true
    }
  },
  "mcpServers": {
    "canvas": {
      "httpUrl": "https://mcp.illinihunt.org/mcp",
      "headers": {
        "X-Canvas-Token": "$CANVAS_TOKEN",
        "X-Canvas-URL": "$CANVAS_API_URL"
      },
      "trust": true,
      "timeout": 60000
    }
  },
  "ui": {
    "footer": {
      "items": [
        "workspace",
        "git-branch",
        "sandbox",
        "model-name",
        "quota",
        "context-used",
        "memory-usage",
        "session-id",
        "code-changes",
        "token-count"
      ]
    }
  },
  "model": {
    "name": "gemini-3.1-pro-preview"
  }
}